<AnchorPane prefHeight="450.0" prefWidth="350.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proje.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="40.0" layoutY="40.0" prefWidth="270.0" spacing="20.0">
         <children>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label text="HOŞ GELDİNİZ" textFill="#2c3e50">
