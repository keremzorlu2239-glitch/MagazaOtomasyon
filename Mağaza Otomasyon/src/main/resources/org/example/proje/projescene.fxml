                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Şifre" style="-fx-font-weight: bold;" textFill="#34495e" />
                        <PasswordField fx:id="txtSifre" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #dcdde1; -fx-border-radius: 10;" />
                     </children>
