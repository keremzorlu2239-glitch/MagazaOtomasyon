            <Button fx:id="btnGiris" mnemonicParsing="false" onAction="#handleGiris" prefHeight="45.0" prefWidth="270.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="GİRİŞ YAP">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
            
