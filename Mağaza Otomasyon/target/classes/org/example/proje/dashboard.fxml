<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="800.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proje.DashboardController">
   <children>
      <VBox prefHeight="550.0" prefWidth="180.0" style="-fx-background-color: #2c3e50; -fx-padding: 20 10 20 10; -fx-spacing: 15;">
         <children>
            <Label text="MAĞAZA PANELİ" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <VBox.margin>
                  <javafx.geometry.Insets bottom="20.0" left="5.0" />
               </VBox.margin>
            </Label>
            
            <Button fx:id="btnUrunler" onAction="#menuUrunTikla" prefHeight="45.0" prefWidth="160.0" 
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 0 0 0 15; -fx-cursor: hand;" text="📦  Ürünler" />
            
            <Button fx:id="btnMusteriler" onAction="#menuMusteriTikla" prefHeight="45.0" prefWidth="160.0" 
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 0 0 0 15; -fx-cursor: hand;" text="👥  Müşteriler" />
            
            <Button fx:id="btnSatis" onAction="#menuSatisTikla" prefHeight="45.0" prefWidth="160.0" 
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 0 0 0 15; -fx-cursor: hand;" text="💰  Satışlar" />
            
            <VBox prefHeight="200.0" VBox.vgrow="ALWAYS" />
            
            <Button fx:id="btnCikis" onAction="#handleCikisYap" prefHeight="45.0" prefWidth="160.0" 
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Çıkış Yap" />
         </children>
      </VBox>

      <TextField fx:id="txtArama" layoutX="200.0" layoutY="20.0" prefHeight="40.0" prefWidth="580.0" promptText="🔍 Listede ara..." 
                 style="-fx-background-radius: 20; -fx-border-color: #bdc3c7; -fx-border-radius: 20; -fx-padding: 0 15 0 15;" />

      <TableView fx:id="anaTablo" layoutX="200.0" layoutY="75.0" prefHeight="300.0" prefWidth="580.0" style="-fx-background-radius: 10;">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <HBox layoutX="200.0" layoutY="390.0" prefHeight="80.0" prefWidth="580.0" spacing="15.0">
         <children>
            <VBox alignment="CENTER" prefWidth="185.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <children>
                  <Label text="TOPLAM MÜŞTERİ" style="-fx-font-size: 10px; -fx-font-weight: bold;" textFill="#95a5a6" />
                  <Label fx:id="lblToplamMusteri" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefWidth="185.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <children>
                  <Label text="TOPLAM ÜRÜN" style="-fx-font-size: 10px; -fx-font-weight: bold;" textFill="#95a5a6" />
                  <Label fx:id="lblToplamUrun" text="0" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefWidth="185.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
               <children>
                  <Label text="TOPLAM CİRO" style="-fx-font-size: 10px; -fx-font-weight: bold;" textFill="#95a5a6" />
                  <Label fx:id="lblToplamKazanc" text="0 TL" style="-fx-font-size: 20px; -fx-font-weight: bold;" textFill="#27ae60" />
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox layoutX="200.0" layoutY="485.0" prefHeight="45.0" prefWidth="580.0" spacing="10.0">
         <children>
            <Button onAction="#urunEklemePenceresiniAc" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="+ Ürün Ekle" />
            <Button onAction="#musteriEklemePenceresiniAc" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="+ Müşteri Ekle" />
            <Button onAction="#satisEklemePenceresiniAc" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🛒 Satış Yap" />
            <Button onAction="#handleSil" prefHeight="45.0" prefWidth="140.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🗑 Sil" />
         </children>
      </HBox>
   </children>
</AnchorPane>